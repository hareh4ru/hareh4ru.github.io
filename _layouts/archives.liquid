---
layout: page
---
<ul class="posts">
{% for post in site.posts %}
  <li>
    <span class="post-date" style="color: var(--text);">{{ post.date | date: "%b %-d, %Y" }}</span>
    <a class="post-link" href="{{ post.url | relative_url }}" style="color: var(--link);">{{ post.title }}</a>
  </li>
{% endfor %}
</ul>